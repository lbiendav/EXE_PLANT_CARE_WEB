<div class="container py-5">

    <div class="row">

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
                         width="140"
                         class="mb-3" />

                    <h3 class="fw-bold">

                        @ViewBag.Name

                    </h3>

                    <p class="text-muted">

                        @ViewBag.Email

                    </p>

                    <span class="badge bg-success">

                        @ViewBag.Role

                    </span>

                </div>

            </div>

        </div>

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <h3 class="fw-bold mb-4">

                        Personal Information

                    </h3>

                    <div class="row mb-3">

                        <div class="col-md-4">

                            <strong>
                                Full Name
                            </strong>

                        </div>

                        <div class="col-md-8">

                            @ViewBag.Name

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4">

                            <strong>
                                Email
                            </strong>

                        </div>

                        <div class="col-md-8">

                            @ViewBag.Email

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4">

                            <strong>
                                Phone
                            </strong>

                        </div>

                        <div class="col-md-8">

                            @ViewBag.Phone

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4">

                            <strong>
                                Role
                            </strong>

                        </div>

                        <div class="col-md-8">

                            @ViewBag.Role

                        </div>

                    </div>

                    <hr />

                    <div class="mt-4">

                        <a class="btn btn-success">

                            Edit Profile

                        </a>

                        <a class="btn btn-outline-primary ms-2">

                            Change Password

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>
</div>
