<div class="container py-5">

    <div class="row">

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body text-center">

                    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
                         width="140"
                         class="mb-3" />

                    <h3 class="fw-bold">

                        @ViewBag.Name

                    </h3>

                    <p class="text-muted">

                        @ViewBag.Email

                    </p>

                    <span class="badge bg-success">

                        @ViewBag.Role

                    </span>

                </div>

            </div>

        </div>

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <h3 class="fw-bold mb-4">

                        @Localizer["Profile_Index_PersonalInfo"]

                    </h3>

                    <div class="row mb-3">

                        <div class="col-md-4">

                            <strong>
                                @Localizer["Profile_Index_FullName"]
                            </strong>

                        </div>

                        <div class="col-md-8">

                            @ViewBag.Name

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4">

                            <strong>
                                @Localizer["Profile_Index_Email"]
                            </strong>

                        </div>

                        <div class="col-md-8">

                            @ViewBag.Email

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4">

                            <strong>
                                @Localizer["Profile_Index_Phone"]
                            </strong>

                        </div>

                        <div class="col-md-8">

                            @ViewBag.Phone

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-3">

                        <div class="col-md-4">

                            <strong>
                                @Localizer["Profile_Index_Role"]
                            </strong>

                        </div>

                        <div class="col-md-8">

                            @ViewBag.Role

                        </div>

                    </div>

                    <hr />

                    <div class="mt-4">

                        <a class="btn btn-success">

                            @Localizer["Profile_Index_EditProfile"]

                        </a>

                        <a class="btn btn-outline-primary ms-2">

                            @Localizer["Profile_Index_ChangePassword"]

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>
</div>
