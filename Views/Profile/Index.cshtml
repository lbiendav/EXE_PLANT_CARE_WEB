@{
    ViewData["Title"] = "Hồ sơ";
}

<div class="mb-4">
    <span class="kicker">Tài khoản</span>
    <h1>Hồ sơ của bạn</h1>
</div>

<div class="row g-4">

    <div class="col-lg-4">

        <div class="card">
            <div class="card-body text-center p-4">

                <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
                     width="110"
                     class="mb-3 rounded-circle"
                     alt="Ảnh đại diện" />

                <h4 class="fw-bold mb-1">@ViewBag.Name</h4>

                <p class="text-muted mb-3">@ViewBag.Email</p>

                <span class="badge bg-success">@ViewBag.Role</span>

            </div>
        </div>

    </div>

    <div class="col-lg-8">

        <div class="card">
            <div class="card-body p-4">

                <h6 class="kicker mb-3">Thông tin cá nhân</h6>

                <div class="field-row">
                    <span class="field-label">Họ và tên</span>
                    <span class="field-value">@ViewBag.Name</span>
                </div>

                <div class="field-row">
                    <span class="field-label">Email</span>
                    <span class="field-value">@ViewBag.Email</span>
                </div>

                <div class="field-row">
                    <span class="field-label">Số điện thoại</span>
                    <span class="field-value">@ViewBag.Phone</span>
                </div>

                <div class="field-row">
                    <span class="field-label">Vai trò</span>
                    <span class="field-value">@ViewBag.Role</span>
                </div>

                <div class="mt-4 d-flex flex-wrap gap-2">

                    <a class="btn btn-success btn-sm">
                        Sửa hồ sơ
                    </a>

                    <a class="btn btn-outline-success btn-sm">
                        Đổi mật khẩu
                    </a>

                </div>

            </div>
        </div>

    </div>

</div>
