@model HomePlant.Models.CareLogModel

@{
    ViewData["Title"] = "Ghi nhật ký chăm sóc";
}

<a asp-action="Index" asp-route-plantId="@ViewBag.PlantId" class="back-link">
    ← Lịch sử chăm sóc
</a>

<div class="mb-4">
    <span class="kicker">Nhật ký</span>
    <h1>Ghi nhật ký chăm sóc</h1>
</div>

<form method="post" style="max-width:520px;">

    <input type="hidden"
           name="plantId"
           value="@ViewBag.PlantId" />

    <div class="mb-3">

        <label class="form-label">Hoạt động</label>

        <select asp-for="ActionType" class="form-select">
            <option value="Watering">Tưới nước</option>
            <option value="Fertilizing">Bón phân</option>
            <option value="Repotting">Thay chậu</option>
            <option value="Observation">Quan sát</option>
        </select>

    </div>

    <div class="mb-4">

        <label class="form-label">Ghi chú</label>

        <textarea asp-for="Note"
                  rows="4"
                  class="form-control"
                  placeholder="Hôm nay cây thế nào?"></textarea>

    </div>

    <button class="btn btn-success">
        Lưu nhật ký
    </button>

</form>
