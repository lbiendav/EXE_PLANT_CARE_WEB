@model List<HomePlant.Models.CareLogModel>

@{
    ViewData["Title"] = "Lịch sử chăm sóc";
}

<a asp-controller="Plant" asp-action="Details" asp-route-id="@ViewBag.PlantId" class="back-link">
    ← Chi tiết cây
</a>

<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
        <span class="kicker">Nhật ký</span>
        <h1 class="mb-0">Lịch sử chăm sóc</h1>
    </div>

    <a asp-action="Create"
       asp-route-plantId="@ViewBag.PlantId"
       class="btn btn-success">
        + Ghi nhật ký
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">

            <thead>
                <tr>
                    <th>Hoạt động</th>
                    <th>Ghi chú</th>
                    <th>Ngày</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.ActionType</td>

                        <td>@item.Note</td>

                        <td class="text-muted">@item.CreatedAt</td>

                        <td class="text-end">
                            <a asp-action="Delete"
                               asp-route-plantId="@ViewBag.PlantId"
                               asp-route-id="@item.Id"
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('Xóa bản ghi này?');">
                                Xóa
                            </a>
                        </td>

                    </tr>
                }

            </tbody>

        </table>
    </div>
</div>
