@model List<HomePlant.Models.CareLogModel>

<h2>@Localizer["CareLog_Index_Title"]</h2>

<a asp-action="Create"
   asp-route-plantId="@ViewBag.PlantId"
   class="btn btn-success mb-3">
    @Localizer["CareLog_Index_AddLog"]
</a>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>@Localizer["CareLog_Index_Type"]</th>
            <th>@Localizer["CareLog_Index_Note"]</th>
            <th>@Localizer["CareLog_Index_Date"]</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>
                    @item.ActionType
                </td>

                <td>
                    @item.Note
                </td>

                <td>
                    @item.CreatedAt
                </td>

                <td>

                    <a asp-action="Delete"
                       asp-route-plantId="@ViewBag.PlantId"
                       asp-route-id="@item.Id"
                       class="btn btn-danger">
                        @Localizer["CareLog_Index_Delete"]
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>