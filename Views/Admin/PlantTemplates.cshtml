@model List<HomePlant.Models.PlantTemplateModel>

<style>
    .admin-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        transition: transform .18s ease, box-shadow .18s ease;
    }

    .admin-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 26px rgba(0,0,0,.12) !important;
    }

    .admin-card img {
        height: 170px;
        width: 100%;
        object-fit: cover;
    }
</style>

<a asp-action="Dashboard" class="text-decoration-none text-success fw-semibold mb-3 d-inline-block">
    ← Quay lại Quản lý
</a>

<h1 class="fw-bold mb-4" style="color:#2e7d32;">🌿 Quản lý mẫu cây (Templates)</h1>

<div class="row g-4">
    @foreach (var t in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card admin-card shadow-sm h-100">
                <img src="@(string.IsNullOrEmpty(t.ImageUrl) ? "https://i.ibb.co/MkMj38WM/plant.png" : t.ImageUrl)" />

                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start">
                        <h6 class="fw-bold mb-0">@t.Name</h6>
                        @if (t.IsFeatured)
                        {
                            <span class="badge bg-warning text-dark">Nổi bật</span>
                        }
                    </div>

                    <small class="text-muted fst-italic mb-2">@t.ScientificName</small>
                    <p class="small text-muted mb-2" style="min-height:60px;">@t.Description</p>

                    <div class="mt-auto">
                        <a asp-action="DeletePlantTemplate"
                           asp-route-id="@t.Id"
                           class="btn btn-outline-danger btn-sm w-100"
                           onclick="return confirm('Xóa mẫu cây này?');">
                            Xóa
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
