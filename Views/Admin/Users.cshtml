@model List<HomePlant.Models.UserModel>

<style>
    .admin-table-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
    }

    .avatar-sm {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
    }

    .role-badge {
        text-transform: capitalize;
    }
</style>

<a asp-action="Dashboard" class="text-decoration-none text-success fw-semibold mb-3 d-inline-block">
    ← Quay lại Quản lý
</a>

<h1 class="fw-bold mb-4" style="color:#2e7d32;">👤 Quản lý người dùng</h1>

<div class="card admin-table-card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">

            <thead class="table-light">
                <tr>
                    <th>Người dùng</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@(string.IsNullOrEmpty(user.AvatarUrl) ? "https://i.pravatar.cc/150" : user.AvatarUrl)"
                                     class="avatar-sm" />
                                <span class="fw-semibold">@user.FullName</span>
                            </div>
                        </td>

                        <td>@user.Email</td>

                        <td>
                            <span class="badge role-badge bg-@(user.Role == "admin" ? "danger" : user.Role == "expert" ? "info" : "secondary")">
                                @user.Role
                            </span>
                        </td>

                        <td>
                            @if (user.IsLocked)
                            {
                                <span class="badge bg-danger">Đã khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>

                        <td>
                            @if (!user.IsLocked)
                            {
                                <a asp-action="Ban"
                                   asp-route-id="@user.Id"
                                   class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Khóa tài khoản này?');">
                                    Khóa
                                </a>
                            }
                            else
                            {
                                <a asp-action="UnBan"
                                   asp-route-id="@user.Id"
                                   class="btn btn-outline-success btn-sm">
                                    Mở khóa
                                </a>
                            }
                        </td>
                    </tr>
                }

            </tbody>

        </table>
    </div>
</div>
