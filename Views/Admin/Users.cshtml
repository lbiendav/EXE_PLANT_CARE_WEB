@model List<HomePlant.Models.UserModel>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

<style>
    .role-badge {
        text-transform: capitalize;
    }
</style>

<a asp-action="Dashboard" class="back-link">
    ← Quản trị
</a>

<div class="mb-4">
    <span class="kicker">Quản trị</span>
    <h1 class="mb-0">Người dùng</h1>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">

            <thead>
                <tr>
                    <th>Người dùng</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@(string.IsNullOrEmpty(user.AvatarUrl) ? "https://i.pravatar.cc/150" : user.AvatarUrl)"
                                     class="avatar-sm" />
                                <span class="fw-semibold">@user.FullName</span>
                            </div>
                        </td>

                        <td>@user.Email</td>

                        <td>
                            <span class="badge role-badge bg-@(user.Role == "admin" ? "danger" : user.Role == "expert" ? "info" : "secondary")">
                                @user.Role
                            </span>
                        </td>

                        <td>
                            @if (user.IsLocked)
                            {
                                <span class="badge bg-danger">Đã khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>

                        <td>
                            @if (!user.IsLocked)
                            {
                                <a asp-action="Ban"
                                   asp-route-id="@user.Id"
                                   class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Khóa tài khoản này?');">
                                    Khóa
                                </a>
                            }
                            else
                            {
                                <a asp-action="UnBan"
                                   asp-route-id="@user.Id"
                                   class="btn btn-outline-success btn-sm">
                                    Mở khóa
                                </a>
                            }
                        </td>
                    </tr>
                }

            </tbody>

        </table>
    </div>
</div>
