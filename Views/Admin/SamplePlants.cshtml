@model List<HomePlant.Models.PlantSampleModel>

<style>
    .admin-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        transition: transform .18s ease, box-shadow .18s ease;
    }

    .admin-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 26px rgba(0,0,0,.12) !important;
    }

    .admin-card img {
        height: 170px;
        width: 100%;
        object-fit: cover;
    }
</style>

<a asp-action="Dashboard" class="text-decoration-none text-success fw-semibold mb-3 d-inline-block">
    ← Quay lại Quản lý
</a>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0" style="color:#2e7d32;">📚 Quản lý thư viện cây</h1>

    <a asp-action="CreateSamplePlant" class="btn btn-success fw-bold px-4">
        + Thêm cây mới
    </a>
</div>

<div class="row g-4">
    @foreach (var p in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card admin-card shadow-sm h-100">
                <img src="@(string.IsNullOrEmpty(p.Image) ? "https://i.ibb.co/MkMj38WM/plant.png" : p.Image)" />

                <div class="card-body d-flex flex-column">
                    <h6 class="fw-bold mb-0">@p.Name</h6>
                    <small class="text-muted fst-italic mb-2">@p.ScientificName</small>
                    <p class="small text-muted mb-2" style="min-height:60px;">@p.Description</p>

                    <div class="mt-auto d-flex gap-2">
                        <a asp-action="EditSamplePlant"
                           asp-route-id="@p.Id"
                           class="btn btn-outline-primary btn-sm flex-fill">
                            Sửa
                        </a>

                        <a asp-action="DeleteSamplePlant"
                           asp-route-id="@p.Id"
                           class="btn btn-outline-danger btn-sm flex-fill"
                           onclick="return confirm('Xóa cây này khỏi thư viện?');">
                            Xóa
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
