@model List<HomePlant.Models.PlantSampleModel>

@{
    ViewData["Title"] = "Quản lý thư viện cây";
}

<style>
    .admin-card img {
        height: 170px;
        width: 100%;
        object-fit: cover;
    }
</style>

<a asp-action="Dashboard" class="back-link">
    ← Quản trị
</a>

<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
        <span class="kicker">Quản trị</span>
        <h1 class="mb-0">Thư viện cây</h1>
    </div>

    <a asp-action="CreateSamplePlant" class="btn btn-success">
        + Thêm cây mới
    </a>
</div>

<div class="row g-4">
    @foreach (var p in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6">
            <div class="card admin-card h-100">
                <img src="@(string.IsNullOrEmpty(p.Image) ? "https://i.ibb.co/MkMj38WM/plant.png" : p.Image)" />

                <div class="card-body d-flex flex-column">
                    <h6 class="fw-bold mb-0">@p.Name</h6>
                    <small class="text-muted fst-italic mb-2">@p.ScientificName</small>
                    <p class="small text-muted mb-2" style="min-height:60px;">@p.Description</p>

                    <div class="mt-auto d-flex gap-2">
                        <a asp-action="EditSamplePlant"
                           asp-route-id="@p.Id"
                           class="btn btn-outline-success btn-sm flex-fill">
                            Sửa
                        </a>

                        <a asp-action="DeleteSamplePlant"
                           asp-route-id="@p.Id"
                           class="btn btn-outline-danger btn-sm flex-fill"
                           onclick="return confirm('Xóa cây này khỏi thư viện?');">
                            Xóa
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
