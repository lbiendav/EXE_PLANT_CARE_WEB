@model HomePlant.ViewModels.AdminDashboardVM

@{
    ViewData["Title"] = "Quản trị";
}

<div class="mb-5">
    <span class="kicker">Quản trị</span>
    <h1 class="mb-0">Toàn cảnh hệ thống</h1>
    <p class="text-muted mb-0 mt-2">Toàn bộ dữ liệu HomePlant trên Firestore</p>
</div>

<div class="row g-3">

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-action="Users" class="admin-stat-card">
            <div class="stat-number">@Model.UserCount</div>
            <div class="stat-label">Người dùng</div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-controller="Article" asp-action="Index" class="admin-stat-card">
            <div class="stat-number">@Model.ArticleCount</div>
            <div class="stat-label">Bài viết</div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-action="PlantTemplates" class="admin-stat-card">
            <div class="stat-number">@Model.PlantTemplateCount</div>
            <div class="stat-label">Mẫu cây</div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-action="SamplePlants" class="admin-stat-card">
            <div class="stat-number">@Model.SamplePlantCount</div>
            <div class="stat-label">Thư viện cây</div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <div class="admin-stat-card">
            <div class="stat-number">@Model.GardenPlantCount</div>
            <div class="stat-label">Cây trong vườn</div>
        </div>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-action="CommunityPosts" class="admin-stat-card">
            <div class="stat-number">@Model.CommunityPostCount</div>
            <div class="stat-label">Bài đăng cộng đồng</div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-action="QaThreads" class="admin-stat-card">
            <div class="stat-number">@Model.QaThreadCount</div>
            <div class="stat-label">Câu hỏi chuyên gia</div>
        </a>
    </div>

    <div class="col-lg-3 col-md-4 col-sm-6">
        <a asp-action="AiDiagnoses" class="admin-stat-card">
            <div class="stat-number">@Model.AiDiagnosisCount</div>
            <div class="stat-label">Chẩn đoán AI</div>
        </a>
    </div>

</div>
