@model List<HomePlant.Models.ArticleModel>

<h2>Plant Articles</h2>

<a asp-action="Create"
   class="btn btn-success mb-3">
    Create Article
</a>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Title</th>
            <th>Views</th>
            <th>Tags</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Title</td>

                <td>@item.Views</td>

                <td>@string.Join(", ", item.Tags)</td>

                <td>

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-primary">
                        View
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger">
                        Delete
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>