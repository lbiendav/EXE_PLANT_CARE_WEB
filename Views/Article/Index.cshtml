@model List<HomePlant.Models.ArticleModel>

@{
    ViewData["Title"] = "Bài viết";
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
        <span class="kicker">Cẩm nang</span>
        <h1 class="mb-0">Bài viết chăm cây</h1>
    </div>

    <a asp-action="Create" class="btn btn-success">
        + Viết bài mới
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">

            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Lượt xem</th>
                    <th>Thẻ</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td class="fw-semibold">@item.Title</td>

                        <td class="text-muted">@item.Views</td>

                        <td class="text-muted">@string.Join(", ", item.Tags)</td>

                        <td class="text-end">
                            <div class="d-inline-flex gap-2">
                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-success btn-sm">
                                    Xem
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    Sửa
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Xóa bài viết này?');">
                                    Xóa
                                </a>
                            </div>
                        </td>

                    </tr>
                }

            </tbody>

        </table>
    </div>
</div>
