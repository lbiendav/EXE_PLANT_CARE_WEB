@model HomePlant.Models.ArticleModel

@{
    ViewData["Title"] = "Sửa bài viết";
}

<a asp-action="Index" class="back-link">
    ← Bài viết
</a>

<div class="mb-4">
    <span class="kicker">Cẩm nang</span>
    <h1>Sửa bài viết</h1>
</div>

<form method="post" style="max-width:720px;">

    <div class="mb-3">
        <label class="form-label">Tiêu đề</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Ảnh bìa (URL)</label>
        <input asp-for="CoverImage" class="form-control" placeholder="https://…" />
    </div>

    <div class="mb-4">
        <label class="form-label">Nội dung</label>
        <textarea asp-for="Content"
                  rows="10"
                  class="form-control"></textarea>
    </div>

    <button class="btn btn-success">
        Cập nhật
    </button>

</form>
