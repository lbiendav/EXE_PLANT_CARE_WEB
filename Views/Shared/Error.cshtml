@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<div class="text-center py-5" style="max-width:560px;margin:0 auto;">

    <span class="kicker">Có gì đó chưa ổn</span>

    <h1 class="mt-2">Đã xảy ra <em>lỗi</em>.</h1>

    <p class="text-muted mt-3">
        Yêu cầu của bạn không thể xử lý được. Hãy thử lại, hoặc quay về trang chủ.
    </p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted small">
            Mã yêu cầu: <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3">
        Về trang chủ
    </a>

</div>
