@using Microsoft.AspNetCore.Http

<!DOCTYPE html>

<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HomePlant</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/HomePlant.styles.css"
          asp-append-version="true" />
</head>

<body>

    <div class="grain"></div>

    <header>

        <nav class="navbar navbar-expand-lg custom-navbar">

            <div class="container">

                <a class="navbar-brand logo-text"
                   asp-controller="Home"
                   asp-action="Index">
                    HomePlant
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse"
                     id="navbarContent">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Khám phá
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Library"
                               asp-action="Index">
                                Thư viện cây
                            </a>
                        </li>

                        @if (Context.Session.GetString("Email") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Plant"
                                   asp-action="Index">
                                    Vườn của tôi
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Profile"
                                   asp-action="Index">
                                    Hồ sơ
                                </a>
                            </li>
                        }

                        @if (string.Equals(Context.Session.GetString("Role"), "admin", StringComparison.OrdinalIgnoreCase))
                        {
                            <li class="nav-item">
                                <a class="nav-link admin-link"
                                   asp-controller="Admin"
                                   asp-action="Dashboard">
                                    Quản trị
                                </a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav align-items-lg-center">

                        @if (Context.Session.GetString("Email") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Đăng nhập
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-success btn-sm ms-lg-3"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Đăng ký
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <span class="user-badge">
                                    @Context.Session.GetString("Email")
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm ms-lg-3"
                                   asp-controller="Account"
                                   asp-action="Logout">
                                    Đăng xuất
                                </a>
                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container mt-5 main-wrap">

        <main role="main">

            @RenderBody()

        </main>

    </div>

    <footer class="footer-custom">

        <div class="container d-flex flex-wrap justify-content-between align-items-baseline gap-3">

            <span class="foot-mark">HomePlant</span>

            <span class="foot-mid">
                Chăm cây <em>trong nhà</em>, có nhịp có mùa.
            </span>

            <span class="foot-right">
                © 2026 HomePlant
            </span>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
