@model HomePlant.ViewModels.PlantCreateVM

@{
    ViewData["Title"] = "Thêm cây mới";
}

<a asp-action="Index" class="back-link">
    ← Vườn của tôi
</a>

<div class="mb-4">
    <span class="kicker">Trang mới trong nhật ký</span>
    <h1>Thêm cây mới</h1>
</div>

<form method="post" enctype="multipart/form-data" style="max-width:520px;">

    <div class="mb-3">
        <label for="Photo"
               id="photoDropzone"
               class="photo-dropzone d-flex flex-column align-items-center justify-content-center text-center p-5"
               style="overflow:hidden;">
            <span id="photoPlaceholder" style="font-size:1.6rem;">＋</span>
            <span id="photoPlaceholderText" class="mt-2">Chạm để thêm ảnh</span>
            <img id="photoPreview" class="d-none" style="max-height:220px;max-width:100%;object-fit:cover;" />
        </label>
        <input type="file" id="Photo" name="Photo" accept="image/*" class="d-none" />
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="Nickname">Tên gọi</label>
        <input asp-for="Nickname"
               class="form-control"
               placeholder="Ví dụ: Bé Sen Đá Góc Bàn" />
        <span asp-validation-for="Nickname" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="PlantSampleId">Loại cây (từ thư viện)</label>
        <select asp-for="PlantSampleId"
                asp-items="ViewBag.PlantSamples"
                class="form-select">
            <option value="">Chọn loại cây</option>
        </select>
        <span asp-validation-for="PlantSampleId" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label class="form-label" asp-for="CurrentStatus">Trạng thái sức khỏe</label>
        <select asp-for="CurrentStatus" class="form-select">
            <option>Khỏe mạnh</option>
            <option>Cần chú ý</option>
            <option>Bị bệnh</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success btn-lg w-100">
        Lưu vào vườn
    </button>

</form>

<script>
    document.getElementById("Photo").addEventListener("change", function () {
        var file = this.files && this.files[0];

        var preview = document.getElementById("photoPreview");
        var placeholder = document.getElementById("photoPlaceholder");
        var placeholderText = document.getElementById("photoPlaceholderText");

        if (!file) {
            preview.classList.add("d-none");
            placeholder.classList.remove("d-none");
            placeholderText.classList.remove("d-none");
            return;
        }

        preview.src = URL.createObjectURL(file);
        preview.classList.remove("d-none");
        placeholder.classList.add("d-none");
        placeholderText.textContent = file.name;
    });
</script>
