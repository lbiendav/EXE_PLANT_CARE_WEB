@model HomePlant.ViewModels.PlantCreateVM

<h2 class="fw-bold mb-4">@Localizer["Plant_Create_Title"]</h2>

<form method="post" enctype="multipart/form-data" style="max-width:500px;">

    <div class="mb-3">
        <label for="Photo"
               id="photoDropzone"
               class="d-flex flex-column align-items-center justify-content-center text-center border rounded-3 p-5"
               style="cursor:pointer;background:#f2f8f2;border-color:#a5d6a7 !important;color:#2e7d32;overflow:hidden;">
            <span id="photoPlaceholder" style="font-size:2rem;">+📷</span>
            <span id="photoPlaceholderText" class="mt-2">@Localizer["Plant_Create_PhotoPlaceholder"]</span>
            <img id="photoPreview" class="d-none" style="max-height:220px;max-width:100%;object-fit:cover;" />
        </label>
        <input type="file" id="Photo" name="Photo" accept="image/*" class="d-none" />
    </div>

    <div class="mb-3">
        <input asp-for="Nickname"
               class="form-control form-control-lg"
               placeholder="@Localizer["Plant_Create_NicknamePlaceholder"]" />
        <span asp-validation-for="Nickname" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <select asp-for="PlantSampleId"
                asp-items="ViewBag.PlantSamples"
                class="form-control form-control-lg">
            <option value="">@Localizer["Plant_Create_TemplateOption"]</option>
        </select>
        <span asp-validation-for="PlantSampleId" class="text-danger"></span>
    </div>

    <div class="mb-4">
        <label class="text-muted small mb-1">@Localizer["Plant_Create_HealthStatusLabel"]</label>
        <select asp-for="CurrentStatus" class="form-control form-control-lg">
            <option>@Localizer["Plant_Create_StatusHealthy"]</option>
            <option>@Localizer["Plant_Create_StatusAttention"]</option>
            <option>@Localizer["Plant_Create_StatusSick"]</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success btn-lg w-100 fw-bold">
        @Localizer["Plant_Create_SaveButton"]
    </button>

</form>

<script>
    document.getElementById("Photo").addEventListener("change", function () {
        var file = this.files && this.files[0];

        var preview = document.getElementById("photoPreview");
        var placeholder = document.getElementById("photoPlaceholder");
        var placeholderText = document.getElementById("photoPlaceholderText");

        if (!file) {
            preview.classList.add("d-none");
            placeholder.classList.remove("d-none");
            placeholderText.classList.remove("d-none");
            return;
        }

        preview.src = URL.createObjectURL(file);
        preview.classList.remove("d-none");
        placeholder.classList.add("d-none");
        placeholderText.textContent = file.name;
    });
</script>
