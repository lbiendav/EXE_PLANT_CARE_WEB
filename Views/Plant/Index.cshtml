@model List<HomePlant.ViewModels.GardenItemVM>

@{
    ViewData["Title"] = "Vườn của tôi";
}

<style>
    .garden-card img {
        height: 210px;
        width: 100%;
        object-fit: cover;
    }

    .garden-img-wrap {
        position: relative;
        overflow: hidden;
    }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-5">
    <div>
        <span class="kicker">Nhật ký làm vườn</span>
        <h1 class="mb-0">Vườn của tôi</h1>
        <p class="text-muted mb-0 mt-2">Tất cả những cây bạn đang chăm sóc</p>
    </div>

    <a asp-action="Create" class="btn btn-success">
        + Thêm cây mới
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="empty-garden text-center py-5 px-4">
        <span class="kicker d-block mb-3">Trang đầu tiên</span>
        <h3>Vườn của bạn còn trống</h3>
        <p class="text-muted">Hãy thêm cây đầu tiên của bạn vào vườn nhé!</p>
        <a asp-action="Create" class="btn btn-success mt-2">Thêm cây mới</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            var plant = item.Plant;
            var template = item.Template;

            <div class="col-lg-4 col-md-6">
                <div class="card garden-card h-100">

                    <div class="garden-img-wrap">
                        <img src="@(string.IsNullOrEmpty(plant.ImageUrl) ? "https://i.ibb.co/MkMj38WM/plant.png" : plant.ImageUrl)"
                             alt="@plant.CustomName" />
                        <span class="status-pill bg-@plant.StatusColorClass">
                            @plant.DisplayStatus
                        </span>
                    </div>

                    <div class="card-body d-flex flex-column">

                        <h5 class="fw-bold mb-0">@plant.CustomName</h5>

                        @if (template != null)
                        {
                            <small class="text-muted fst-italic mb-3">
                                @template.Name · @template.ScientificName
                            </small>
                        }
                        else
                        {
                            <small class="text-muted fst-italic mb-3">Không rõ loại cây</small>
                        }

                        <div class="mb-3">
                            <div class="fact-row">
                                <span class="fact-label">Ngày trồng</span>
                                <span class="fact-value">@plant.PlantedAt.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">Tưới nước gần nhất</span>
                                <span class="fact-value">
                                    @(plant.LastWatered.HasValue ? plant.LastWatered.Value.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy") : "Chưa có")
                                </span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">Tần suất tưới</span>
                                <span class="fact-value">@(plant.WateringFrequency.HasValue ? $"{plant.WateringFrequency} ngày/lần" : "—")</span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">Bón phân gần nhất</span>
                                <span class="fact-value">
                                    @(plant.LastFertilized.HasValue ? plant.LastFertilized.Value.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy") : "Chưa có")
                                </span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">Tần suất bón phân</span>
                                <span class="fact-value">@(plant.FertilizingFrequency.HasValue ? $"{plant.FertilizingFrequency} ngày/lần" : "—")</span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">Thay chậu gần nhất</span>
                                <span class="fact-value">
                                    @(plant.LastRepotted.HasValue ? plant.LastRepotted.Value.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy") : "Chưa có")
                                </span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">Tần suất thay chậu</span>
                                <span class="fact-value">@(plant.RepottingFrequency.HasValue ? $"{plant.RepottingFrequency} ngày/lần" : "—")</span>
                            </div>
                        </div>

                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Details"
                               asp-route-id="@plant.Id"
                               class="btn btn-outline-success btn-sm flex-fill">
                                Xem chi tiết
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@plant.Id"
                               class="btn btn-outline-danger btn-sm flex-fill"
                               onclick="return confirm('Xóa cây này khỏi vườn?');">
                                Xóa
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}
