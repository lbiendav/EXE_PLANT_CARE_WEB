@model List<HomePlant.ViewModels.GardenItemVM>

<style>
    .garden-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .garden-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 28px rgba(0,0,0,.12) !important;
    }

    .garden-card .garden-img-wrap {
        position: relative;
    }

    .garden-card img {
        height: 210px;
        width: 100%;
        object-fit: cover;
    }

    .status-pill {
        position: absolute;
        top: 12px;
        right: 12px;
        padding: 4px 12px;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 600;
        color: #fff;
        box-shadow: 0 2px 6px rgba(0,0,0,.25);
    }

    .fact-row {
        display: flex;
        justify-content: space-between;
        font-size: .82rem;
        padding: 4px 0;
        border-bottom: 1px dashed #e7e7e7;
    }

    .fact-row:last-child {
        border-bottom: none;
    }

    .fact-label {
        color: #7a8a7a;
    }

    .fact-value {
        font-weight: 600;
        color: #2e2e2e;
    }

    .empty-garden {
        border: 2px dashed #a5d6a7;
        border-radius: 20px;
        background: #f5faf5;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-0" style="color:#2e7d32;">@Localizer["Plant_Index_Title"]</h1>
        <p class="text-muted mb-0">@Localizer["Plant_Index_Subtitle"]</p>
    </div>

    <a asp-action="Create" class="btn btn-success btn-lg fw-bold px-4">
        @Localizer["Plant_Index_AddNewPlant"]
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="empty-garden text-center py-5">
        <div style="font-size:3rem;">🌱</div>
        <h4 class="fw-bold mt-2" style="color:#2e7d32;">@Localizer["Plant_Index_EmptyTitle"]</h4>
        <p class="text-muted">@Localizer["Plant_Index_EmptySubtitle"]</p>
        <a asp-action="Create" class="btn btn-success fw-bold px-4">@Localizer["Plant_Index_EmptyAddButton"]</a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            var plant = item.Plant;
            var template = item.Template;

            <div class="col-lg-4 col-md-6">
                <div class="card garden-card shadow-sm h-100">

                    <div class="garden-img-wrap">
                        <img src="@(string.IsNullOrEmpty(plant.ImageUrl) ? "https://i.ibb.co/MkMj38WM/plant.png" : plant.ImageUrl)" />
                        <span class="status-pill bg-@plant.StatusColorClass">
                            @plant.DisplayStatus
                        </span>
                    </div>

                    <div class="card-body d-flex flex-column">

                        <h5 class="fw-bold mb-0">@plant.CustomName</h5>

                        @if (template != null)
                        {
                            <small class="text-muted fst-italic mb-2">
                                @template.Name · @template.ScientificName
                            </small>
                        }
                        else
                        {
                            <small class="text-muted fst-italic mb-2">@Localizer["Plant_Index_UnknownPlantType"]</small>
                        }

                        <div class="mb-3">
                            <div class="fact-row">
                                <span class="fact-label">@Localizer["Plant_Index_PlantedAt"]</span>
                                <span class="fact-value">@plant.PlantedAt.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">@Localizer["Plant_Index_LastWatered"]</span>
                                <span class="fact-value">
                                    @(plant.LastWatered.HasValue ? plant.LastWatered.Value.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy") : Localizer["Plant_Index_None"].Value)
                                </span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">@Localizer["Plant_Index_WateringFrequency"]</span>
                                <span class="fact-value">@(plant.WateringFrequency.HasValue ? $"{plant.WateringFrequency} {Localizer["Plant_Index_DaysPerTime"].Value}" : "—")</span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">@Localizer["Plant_Index_LastFertilized"]</span>
                                <span class="fact-value">
                                    @(plant.LastFertilized.HasValue ? plant.LastFertilized.Value.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy") : Localizer["Plant_Index_None"].Value)
                                </span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">@Localizer["Plant_Index_FertilizingFrequency"]</span>
                                <span class="fact-value">@(plant.FertilizingFrequency.HasValue ? $"{plant.FertilizingFrequency} {Localizer["Plant_Index_DaysPerTime"].Value}" : "—")</span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">@Localizer["Plant_Index_LastRepotted"]</span>
                                <span class="fact-value">
                                    @(plant.LastRepotted.HasValue ? plant.LastRepotted.Value.ToDateTime().ToLocalTime().ToString("dd/MM/yyyy") : Localizer["Plant_Index_None"].Value)
                                </span>
                            </div>
                            <div class="fact-row">
                                <span class="fact-label">@Localizer["Plant_Index_RepottingFrequency"]</span>
                                <span class="fact-value">@(plant.RepottingFrequency.HasValue ? $"{plant.RepottingFrequency} {Localizer["Plant_Index_DaysPerTime"].Value}" : "—")</span>
                            </div>
                        </div>

                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Details"
                               asp-route-id="@plant.Id"
                               class="btn btn-success btn-sm flex-fill fw-semibold">
                                @Localizer["Plant_Index_ViewDetails"]
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@plant.Id"
                               class="btn btn-outline-danger btn-sm flex-fill"
                               onclick="return confirm('@Localizer["Plant_Index_DeleteConfirm"]');">
                                @Localizer["Plant_Index_Delete"]
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}
