@model HomePlant.ViewModels.LoginVM

<h2>Login</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form method="post">

    <div class="mb-3">
        <label>Email</label>

        <input asp-for="Email"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>

        <input asp-for="Password"
               type="password"
               class="form-control" />
    </div>

    <button class="btn btn-primary">
        Login
    </button>

</form>