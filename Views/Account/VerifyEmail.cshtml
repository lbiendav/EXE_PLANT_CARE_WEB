@{
    ViewData["Title"] = "Xác thực email";
    bool success = ViewBag.Success;
}

<div class="text-center py-5" style="max-width:520px;margin:0 auto;">
    @if (success)
    {
        <span class="kicker">Chào mừng</span>

        <h1 class="mt-2">Xác thực <em>thành công</em>.</h1>

        <p class="text-muted mt-3">
            Email của bạn đã được xác thực. Bây giờ bạn có thể đăng nhập vào HomePlant.
        </p>

        <a asp-action="Login" class="btn btn-success mt-3">
            Đăng nhập ngay
        </a>
    }
    else
    {
        <span class="kicker">Có gì đó chưa ổn</span>

        <h1 class="mt-2 text-danger">Xác thực chưa hoàn tất</h1>

        <p class="text-muted mt-3">
            Liên kết không hợp lệ hoặc email chưa được xác thực. Vui lòng thử lại từ email đã nhận được.
        </p>

        <a asp-action="Login" class="btn btn-outline-success mt-3">
            Quay lại đăng nhập
        </a>
    }
</div>
