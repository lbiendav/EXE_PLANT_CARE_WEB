@{
    bool success = ViewBag.Success;
}

<div class="text-center py-5" style="max-width:480px;margin:0 auto;">
    @if (success)
    {
        <div style="font-size:3rem;">✅</div>

        <h3 class="fw-bold mt-3" style="color:#2e7d32;">Xác thực thành công!</h3>

        <p class="text-muted mt-2">
            Email của bạn đã được xác thực. Bây giờ bạn có thể đăng nhập vào HomePlant.
        </p>

        <a asp-action="Login" class="btn btn-success fw-bold px-4 mt-3">
            Đăng nhập ngay
        </a>
    }
    else
    {
        <div style="font-size:3rem;">⚠️</div>

        <h3 class="fw-bold mt-3 text-danger">Xác thực chưa hoàn tất</h3>

        <p class="text-muted mt-2">
            Liên kết không hợp lệ hoặc email chưa được xác thực. Vui lòng thử lại từ email đã nhận được.
        </p>

        <a asp-action="Login" class="btn btn-outline-secondary fw-bold px-4 mt-3">
            Quay lại đăng nhập
        </a>
    }
</div>
