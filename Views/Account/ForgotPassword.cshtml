@model HomePlant.ViewModels.ForgotPasswordVM
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu — HomePlant</title>
    <partial name="_AuthStyles" />
</head>
<body class="auth-body">
    <div class="auth-grain"></div>

    <main class="auth-split">

        <aside class="auth-aside">
            <a class="auth-mark" asp-controller="Home" asp-action="Index">HomePlant</a>

            <div>
                <p class="auth-kicker">Vườn trong nhà</p>
                <h2>Quên mật khẩu <em>cũng không sao</em>.</h2>
                <p class="auth-aside__copy">
                    Nhập email của bạn, chúng tôi sẽ gửi liên kết để đặt lại mật khẩu
                    và bạn sẽ sớm quay lại với khu vườn của mình.
                </p>
            </div>
        </aside>

        <section class="auth-panel">
            <div class="auth-panel__inner">
                <h1 class="auth-title">Quên mật khẩu</h1>
                <p class="auth-sub">Nhập email đã dùng để đăng ký.</p>

                <div asp-validation-summary="All" class="auth-alert"></div>

                <form method="post">
                    <div class="auth-field">
                        <label asp-for="Email">Email</label>
                        <div class="auth-input">
                            <input asp-for="Email" placeholder="you@example.com" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="auth-err"></span>
                    </div>

                    <button class="auth-btn" type="submit">Gửi liên kết đặt lại</button>
                </form>

                <p class="auth-foot">
                    Nhớ ra mật khẩu rồi?
                    <a asp-action="Login">Đăng nhập</a>
                </p>
            </div>
        </section>

    </main>
</body>
</html>
