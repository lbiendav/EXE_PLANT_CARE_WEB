@model string

@{
    ViewData["Title"] = "Kiểm tra email";
}

<div class="text-center py-5" style="max-width:520px;margin:0 auto;">

    <span class="kicker">Hạt đã gieo</span>

    <h1 class="mt-2">Kiểm tra email của bạn</h1>

    <p class="text-muted mt-3">
        Chúng tôi đã gửi một liên kết xác thực đến <strong class="text-success">@Model</strong>.
        Nhấp vào liên kết đó để kích hoạt tài khoản trước khi đăng nhập.
    </p>

    <a asp-action="Login" class="btn btn-success mt-3">
        Quay lại đăng nhập
    </a>

</div>
