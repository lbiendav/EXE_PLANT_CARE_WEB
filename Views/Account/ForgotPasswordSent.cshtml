@model string

@{
    ViewData["Title"] = "Kiểm tra email";
}

<div class="text-center py-5" style="max-width:520px;margin:0 auto;">

    <span class="kicker">Đã gửi</span>

    <h1 class="mt-2">Kiểm tra email của bạn</h1>

    <p class="text-muted mt-3">
        Nếu <strong class="text-success">@Model</strong> có trong hệ thống, chúng tôi đã gửi một
        liên kết để đặt lại mật khẩu. Vui lòng kiểm tra hộp thư (và cả mục thư rác).
    </p>

    <a asp-action="Login" class="btn btn-success mt-3">
        Quay lại đăng nhập
    </a>

</div>
