@{
    ViewData["Title"] = "Khám phá";
    var plants = ViewBag.FeaturedPlants;
    var articles = ViewBag.Articles;
}

<!-- HERO -->
<div class="hero mb-5">

    <span class="kicker">HomePlant — Vườn trong nhà</span>

    <h1>Đưa thiên nhiên <em>về nhà bạn</em>.</h1>

    <p class="mt-4">
        Hàng trăm loài cây cảnh, cẩm nang chăm sóc theo mùa
        và một cuốn nhật ký cho khu vườn của riêng bạn.
    </p>

    <a asp-controller="Library"
       asp-action="Index"
       class="btn btn-success btn-lg mt-4">
        Khám phá thư viện cây
    </a>

</div>

<!-- CARE GUIDES -->
<div class="mb-4 mt-5">
    <span class="kicker">Cẩm nang</span>
    <h2>Chăm sóc theo kinh nghiệm</h2>
</div>

<div class="row g-4">

    @if (articles != null)
    {
        @foreach (var article in articles)
        {
            var preview = ((string)article.Content).Replace("#", "").Trim();

            <div class="col-md-4">

                <div class="card h-100">

                    <div class="card-body d-flex flex-column p-4">

                        <h5 class="fw-bold">@article.Title</h5>

                        <p class="text-muted small mt-2">
                            @(preview.Length > 120 ? preview.Substring(0, 120) + "…" : preview)
                        </p>

                        <div class="mt-auto pt-3">
                            <a asp-controller="Article"
                               asp-action="Details"
                               asp-route-id="@article.Id"
                               class="btn btn-outline-success btn-sm">
                                Đọc thêm
                            </a>
                        </div>

                    </div>

                </div>

            </div>
        }
    }

</div>

<!-- ABOUT -->
<div class="surface p-5 mt-5">

    <div class="row align-items-center g-5">

        <div class="col-md-6">

            <span class="kicker">Vì sao</span>

            <h2>Chăm cây, <em>không đoán mò</em>.</h2>

            <p class="mt-3 text-muted">
                HomePlant giúp người mới bắt đầu dễ dàng chăm sóc cây cảnh
                qua thư viện kiến thức phong phú, hướng dẫn xử lý bệnh
                và nhật ký cho khu vườn cá nhân.
            </p>

        </div>

        <div class="col-md-6">

            <img src="https://images.unsplash.com/photo-1485955900006-10f4d324d411?auto=format&fit=crop&w=800&q=80"
                 class="img-fluid"
                 alt="Cây cảnh trong nhà" />

        </div>

    </div>

</div>
