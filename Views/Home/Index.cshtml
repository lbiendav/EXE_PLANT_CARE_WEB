@{
    var plants = ViewBag.FeaturedPlants;
    var articles = ViewBag.Articles;
}

<!-- HERO SECTION -->
<div class="p-5 mb-5 rounded-4 text-white"
     style="
     background:
     linear-gradient(rgba(0,0,0,.45),
     rgba(0,0,0,.45)),
     url('https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?auto=format&fit=crop&w=1600&q=80');
     background-size:cover;
     background-position:center;">

    <div class="container py-5">

        <h1 class="display-4 fw-bold">
            @Localizer["Home_Hero_Title"]
        </h1>

        <p class="lead mt-3">
            @Localizer["Home_Hero_Desc"]
        </p>

        <a asp-controller="Library"
           asp-action="Index"
           class="btn btn-success btn-lg mt-3">

            @Localizer["Home_Explore_Btn"]

        </a>

    </div>

</div>

<!-- CARE GUIDES -->

<hr class="my-5" />

<div class="d-flex justify-content-between align-items-center mb-3">

    <h2 class="fw-bold">
        @Localizer["Home_CareGuide_Title"]
    </h2>

</div>

<div class="row">

    @if (articles != null)
    {
        @foreach (var article in articles)
        {
            <div class="col-md-4">

                <div class="card border-0 shadow-sm mb-4">

                    <div class="card-body">

                        <h5 class="fw-bold">

                            @article.Title

                        </h5>

                        <p>

                            @(article.Content.Length > 120
                                                ? article.Content.Substring(0, 120) + "..."
                                                : article.Content)

                </p>

                        <a asp-controller="Article"
                           asp-action="Details"
                           asp-route-id="@article.Id"
                           class="btn btn-outline-success">

                            @Localizer["Home_ReadMore"]

                        </a>

                    </div>

                </div>

            </div>
        }
    }

</div>

<!-- ABOUT -->

<div class="bg-white shadow-sm rounded-4 p-5 mt-5">

    <div class="row align-items-center">

        <div class="col-md-6">

            <h2 class="fw-bold">

                @Localizer["Home_Why_Title"]

            </h2>

            <p class="mt-3">

                @Localizer["Home_Why_Desc"]

            </p>

        </div>

        <div class="col-md-6 text-center">

            <img src="https://images.unsplash.com/photo-1485955900006-10f4d324d411?auto=format&fit=crop&w=800&q=80"
                 class="img-fluid rounded-4 shadow" />

        </div>

    </div>

</div>