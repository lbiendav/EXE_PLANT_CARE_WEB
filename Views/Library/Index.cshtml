@model List<HomePlant.Models.PlantSampleModel>

@{
    ViewData["Title"] = "Thư viện cây";
}

<div class="mb-4">
    <span class="kicker">Thư viện</span>
    <h1>Danh mục cây cảnh</h1>
    <p class="text-muted mt-2">Khám phá bộ sưu tập cây cảnh và hướng dẫn chăm sóc</p>
</div>

<div class="row mb-5">
    <div class="col-md-6">

        <input type="text"
               id="searchInput"
               class="form-control form-control-lg"
               placeholder="Tìm kiếm cây…" />

    </div>
</div>

<div class="row g-4" id="plantContainer">
    @foreach (var plant in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6 plant-item">

            <div class="card h-100 plant-card">

                <img src="@plant.Image"
                     class="card-img-top"
                     alt="@plant.Name" />

                <div class="card-body d-flex flex-column">

                    <h5 class="fw-bold plant-name mb-0">
                        @plant.Name
                    </h5>

                    <small class="text-muted fst-italic mb-3">
                        @plant.ScientificName
                    </small>

                    <div class="mt-auto">

                        <a asp-controller="Library"
                           asp-action="Details"
                           asp-route-id="@plant.Id"
                           class="btn btn-outline-success btn-sm w-100">
                            Xem chi tiết
                        </a>

                    </div>

                </div>

            </div>

        </div>
    }
</div>

@section Scripts
{
    <script>
        const searchInput = document.getElementById("searchInput");

        searchInput.addEventListener("keyup", function () {
            let keyword = this.value.toLowerCase();
            let plants = document.querySelectorAll(".plant-item");

            plants.forEach(function (item) {
                let name = item.querySelector(".plant-name").innerText.toLowerCase();
                item.style.display = name.includes(keyword) ? "" : "none";
            });
        });
    </script>
}
