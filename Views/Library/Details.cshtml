@model HomePlant.Models.PlantSampleModel

<div class="container py-5">

    <div class="row g-5">

        <div class="col-lg-5">

            <div class="detail-image">

                <img src="@Model.Image"
                     class="img-fluid w-100 rounded-4 shadow-lg" />

            </div>

        </div>

        <div class="col-lg-7">

            <span class="badge bg-success mb-3">

                Plant Information

            </span>

            <h1 class="fw-bold">

                @Model.Name

            </h1>

            <h4 class="text-muted mb-4">

                @Model.ScientificName

            </h4>

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <h5 class="fw-bold">

                        Description

                    </h5>

                    <p class="mb-0">

                        @Model.Description

                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="mt-5">

        <h2 class="fw-bold mb-4">

            Care Guide

        </h2>

        <div class="row">

            <div class="col-md-6 mb-3">

                <div class="card border-0 shadow-sm h-100">

                    <div class="card-body">

                        <h5>
                            ☀️ Ánh sáng
                        </h5>

                        <p>
                            @Model.Care.Light
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-6 mb-3">

                <div class="card border-0 shadow-sm h-100">

                    <div class="card-body">

                        <h5>
                            💧 Tưới nước
                        </h5>

                        <p>
                            @Model.Care.Water
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-6 mb-3">

                <div class="card border-0 shadow-sm h-100">

                    <div class="card-body">

                        <h5>
                            🌱 Đất trồng
                        </h5>

                        <p>
                            @Model.Care.Soil
                        </p>

                    </div>

                </div>

            </div>

            <div class="col-md-6 mb-3">

                <div class="card border-0 shadow-sm h-100">

                    <div class="card-body">

                        <h5>
                            🌿 Phân bón
                        </h5>

                        <p>
                            @Model.Care.Fertilizer
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="mt-5">

        <h2 class="fw-bold mb-4">

            Common Diseases

        </h2>

        @foreach (var disease in Model.Diseases)
        {
            <div class="card border-0 shadow-sm mb-4">

                <div class="card-body">

                    <h4 class="text-danger fw-bold">

                        @disease.Issue

                    </h4>

                    <hr />

                    <h6 class="fw-bold">

                        Nguyên nhân

                    </h6>

                    <p>

                        @disease.Cause

                    </p>

                    <h6 class="fw-bold">

                        Cách xử lý

                    </h6>

                    <p>

                        @disease.Treatment

                    </p>

                </div>

            </div>
        }

    </div>

    <div class="mt-4">

        <a asp-controller="Library"
           asp-action="Index"
           class="btn btn-outline-success btn-lg">

            ← Quay lại thư viện

        </a>

    </div>

</div>
